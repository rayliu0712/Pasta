<Window
  x:Class="Pasta.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Pasta"
  Background="#FFFFFF"
  Icon="icon.ico"
  MouseLeftButtonDown="Window_MouseLeftButtonDown"
  ResizeMode="CanMinimize"
  SizeToContent="WidthAndHeight"
  Topmost="True">

  <Window.Resources>
    <Style TargetType="Button">
      <Setter Property="Background" Value="#F0F0F0" />
      <Setter Property="Foreground" Value="#000000" />
      <Setter Property="BorderBrush" Value="#CCCCCC" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border
              Padding="{TemplateBinding Padding}"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="1"
              CornerRadius="3">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#E0E0E0" />
        </Trigger>
        <Trigger Property="IsPressed" Value="True">
          <Setter Property="Background" Value="#D0D0D0" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style
      x:Key="PrimaryButton"
      BasedOn="{StaticResource {x:Type Button}}"
      TargetType="Button">
      <Setter Property="Background" Value="#0078D4" />
      <Setter Property="BorderBrush" Value="#0078D4" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#1A86D8" />
          <Setter Property="BorderBrush" Value="#1A86D8" />
        </Trigger>
        <Trigger Property="IsPressed" Value="True">
          <Setter Property="Background" Value="#006CBE" />
          <Setter Property="BorderBrush" Value="#006CBE" />
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <DockPanel Margin="48,0">
    <TextBlock
      Margin="0,0,0,12"
      HorizontalAlignment="Center"
      DockPanel.Dock="Bottom">
      <Hyperlink
        Foreground="#0066CC"
        NavigateUri="https://github.com/rayliu0712/Pasta"
        RequestNavigate="Hyperlink_RequestNavigate">
        GitHub
      </Hyperlink>
    </TextBlock>
    <StackPanel
      Margin="24"
      HorizontalAlignment="Center"
      VerticalAlignment="Center">
      <Button
        MinWidth="120"
        Margin="0,0,0,12"
        Padding="32,10"
        Click="EditContentButton_Click">
        編輯內容
      </Button>
      <Button
        MinWidth="120"
        Margin="0,0,0,12"
        Padding="32,10"
        Click="EditImagesButton_Click">
        編輯圖片
      </Button>
      <Button
        MinWidth="120"
        Margin="0,0,0,12"
        Padding="32,10"
        Click="CopyContentButton_Click"
        Style="{StaticResource PrimaryButton}">
        複製內容
      </Button>
      <Button
        MinWidth="120"
        Margin="0,0,0,12"
        Padding="32,10"
        Click="CopyImagesButton_Click"
        Style="{StaticResource PrimaryButton}">
        複製圖片
      </Button>
      <TextBlock
        x:Name="StatusText"
        HorizontalAlignment="Center"
        TextWrapping="Wrap"
        Visibility="Hidden" />
    </StackPanel>
  </DockPanel>
</Window>
